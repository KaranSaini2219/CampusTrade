# ===========================================
# CampusTrade NITJ - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB (use MongoDB Atlas for production)
MONGODB_URI=mongodb://localhost:27017/campustrade-nitj

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Allowed college email domains (comma-separated)
# Only students with these domains can register
ALLOWED_EMAIL_DOMAINS=nitj.ac.in

# Cloudinary (for image uploads)
# Get from https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
